rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profil utilisateur
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Sous-collection des paramètres
      match /settings/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Transactions par utilisateur
    match /transactions/{uid}/items/{transactionId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Stocks par utilisateur
    match /stocks/{uid}/items/{stockId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Notes par utilisateur
    match /notes/{uid}/items/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}